# RocketRide server (auto-populated by the VS Code extension)
ROCKETRIDE_URI=http://localhost:5565
ROCKETRIDE_APIKEY=your-rocketride-api-key

# Anthropic Claude — used by all three BEACON agents
ROCKETRIDE_ANTHROPIC_KEY=sk-ant-your-key-here

# Qdrant — local vector store for transit rulebooks (default port 6333)
ROCKETRIDE_QDRANT_HOST=localhost
ROCKETRIDE_QDRANT_COLLECTION=beacon_protocols

# Dispatch API — receives call_emergency_services / page_supervisor / regulatory_hold calls
ROCKETRIDE_DISPATCH_API_URL=https://dispatch.your-transit-agency.com/api

# Fleet Management API — used by Incident Analyst to check available coaches
ROCKETRIDE_FLEET_API_URL=https://fleet.your-transit-agency.com/api

# Photon Spectrum iMessage Gateway — used by Comms Writer to send passenger alerts
ROCKETRIDE_PHOTON_GATEWAY_URL=https://gateway.photonspectrum.com/api
